# =============================================================================
#  Media Vault — environment template.
#  Copy to .env (`cp .env.example .env`) and adjust. NEVER commit your real .env.
# =============================================================================

# --- MySQL --------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=media_vault
MYSQL_USER=vault
MYSQL_PASSWORD=change-me-app

# SQLAlchemy URL the BACKEND uses to reach MySQL (service name "db" on the
# compose network). Must match MYSQL_USER / MYSQL_PASSWORD / MYSQL_DATABASE.
DATABASE_URL=mysql+pymysql://vault:change-me-app@db:3306/media_vault

# --- JWT ----------------------------------------------------------------------
# Generate a strong value, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-to-a-long-random-secret

# --- MinIO (object storage) ---------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio

# What the BACKEND uses to reach MinIO (internal compose endpoint).
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-minio
MINIO_BUCKET=media
MINIO_SECURE=false
# Browser-reachable endpoint, for optional presigned download links.
MINIO_PUBLIC_ENDPOINT=localhost:9000

# --- Backend / CORS -----------------------------------------------------------
# Origin(s) allowed to call the API from a browser (the Vite dev server).
CORS_ORIGINS=http://localhost:5173

# Max upload size in MB (default 1 GB). NOTE: uploads are buffered in memory for
# validation, so very large values raise the per-request RAM cost.
MAX_UPLOAD_MB=1024

# --- Frontend (Vite, build-time) ----------------------------------------------
# Browser -> backend base URL. The browser cannot resolve "backend:5000",
# so this is localhost.
VITE_API_URL=http://localhost:5000
# Client-side upload-size hint (should match MAX_UPLOAD_MB).
VITE_MAX_UPLOAD_MB=1024
